<%
const posts = page.posts && typeof page.posts.toArray === 'function' ? page.posts.toArray() : [];
const featured = posts[0];
const recent = featured ? posts.slice(1) : posts;
const latest = site.posts && site.posts.length ? site.posts.sort('-date').toArray()[0] : null;
function summaryOf(post) {
  const plain = strip_html((post.excerpt || post.content || '')).replace(/\s+/g, ' ').trim();
  return post.description || plain.slice(0, 110) + (plain.length > 110 ? '...' : '');
}
%>

<section class="hero panel reveal">
  <div class="hero-copy">
    <% if (theme.hero.eyebrow) { %>
      <p class="eyebrow"><%= theme.hero.eyebrow %></p>
    <% } %>
    <h1><%= theme.hero.title %></h1>
    <p class="hero-text"><%= theme.hero.description %></p>

    <div class="hero-actions">
      <a class="button button-primary" href="#recent-posts"><%= theme.hero.cta_primary %></a>
      <a class="button button-secondary" href="<%- url_for('/about/') %>"><%= theme.hero.cta_secondary %></a>
    </div>
  </div>

  <aside class="hero-side">
    <div class="mini-panel">
      <p class="mini-label"><%= theme.hero.note_title %></p>
      <h2 class="mini-title"><%= latest ? latest.title : config.title %></h2>
      <p><%= theme.hero.note_text %></p>
      <% if (latest) { %>
        <a class="text-link" href="<%- url_for(latest.path) %>">最近更新</a>
      <% } %>
    </div>

    <div class="stats-panel">
      <div>
        <span class="stat-number"><%= site.posts.length %></span>
        <span class="stat-label">文章</span>
      </div>
      <div>
        <span class="stat-number"><%= site.categories.length %></span>
        <span class="stat-label">分类</span>
      </div>
      <div>
        <span class="stat-number"><%= site.tags.length %></span>
        <span class="stat-label">标签</span>
      </div>
    </div>
  </aside>
</section>

<% if (featured) { %>
  <section class="panel reveal">
    <div class="section-head">
      <div>
        <p class="eyebrow">Featured Story</p>
        <h2>本周主打</h2>
      </div>
    </div>

    <article class="feature-card">
      <div class="meta-row">
        <span><%= date(featured.date, 'YYYY.MM.DD') %></span>
        <span><%= featured.categories && featured.categories.length ? featured.categories.first().name : '随笔' %></span>
      </div>
      <h3><a href="<%- url_for(featured.path) %>"><%= featured.title %></a></h3>
      <p><%= summaryOf(featured) %></p>
      <a class="text-link" href="<%- url_for(featured.path) %>">阅读这篇文章</a>
    </article>
  </section>
<% } %>

<section id="recent-posts" class="panel reveal">
  <div class="section-head">
    <div>
      <p class="eyebrow">Recent Writing</p>
      <h2>最近文章</h2>
    </div>
    <a class="text-link" href="<%- url_for('/archives/') %>">查看全部归档</a>
  </div>

  <div class="post-grid">
    <% recent.forEach((post) => { %>
      <article class="post-card reveal">
        <div class="meta-row">
          <span><%= date(post.date, 'YYYY.MM.DD') %></span>
          <span><%= post.tags && post.tags.length ? post.tags.first().name : '文章' %></span>
        </div>
        <h3><a href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
        <p><%= summaryOf(post) %></p>
        <div class="meta-row meta-row-bottom">
          <span><%= post.categories && post.categories.length ? post.categories.first().name : '未分类' %></span>
          <a class="text-link" href="<%- url_for(post.path) %>">继续阅读</a>
        </div>
      </article>
    <% }) %>
  </div>

  <%- partial('partials/pagination') %>
</section>
