<% if ((page.total || 1) > 1) { %>
  <nav class="pagination" aria-label="文章分页">
    <div class="pagination-links">
    <% if (page.prev) { %>
      <a class="button button-secondary" href="<%- url_for(page.prev_link) %>">上一页</a>
    <% } %>
    <% if (page.next) { %>
      <a class="button button-secondary" href="<%- url_for(page.next_link) %>">下一页</a>
    <% } %>
    </div>
    <span class="pagination-status">第 <%= page.current || 1 %> / <%= page.total || 1 %> 页</span>
  </nav>
<% } %>
